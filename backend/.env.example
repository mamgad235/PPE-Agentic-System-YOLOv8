# Copy to .env and fill in. .env is gitignored.

# LLM provider used by the analytics + escalation agents.
# Default is Groq — free tier at https://console.groq.com (no credit card).
LLM_PROVIDER=groq

# Groq API key — required for Phase 2+ (analytics agent).
GROQ_API_KEY=your_groq_api_key_here

# Optional alternate (uncomment if switching LLM_PROVIDER to gemini).
# GEMINI_API_KEY=
