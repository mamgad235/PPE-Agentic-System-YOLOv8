# ─── BACKEND (PYTHON) ───
backend/venv/
backend/__pycache__/
backend/datasets/
backend/external_test/
backend/translate_labels.py
.idea/

# Ignore standalone model files in the backend root
backend/*.pt

# Ignore all run folders...
backend/runs/*
# ...but explicitly dive into detect and ignore everything EXCEPT your specific train and val folders
!backend/runs/detect/
backend/runs/detect/*

# Keep your model checkpoints and training graphs
!backend/runs/detect/train4/
!backend/runs/detect/train6/

# Keep your validation evaluations
!backend/runs/detect/val/
!backend/runs/detect/val2/
!backend/runs/detect/val3/

# ─── FRONTEND (NODE/REACT) ───
frontend/node_modules/
frontend/dist/
frontend/.eslintcache

# ─── AGENT LAYER (secrets + local data) ───
backend/.env
backend/agent/ppe_guard.db
backend/agent/reports/

# ─── PYTHON CACHES (any folder, incl. backend/agent/) ───
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# ─── SECRETS (any location) — keep .env.example tracked ───
.env
.env.local
!.env.example

# ─── EDITOR / OS JUNK ───
.vscode/
.DS_Store
Thumbs.db
desktop.ini

# ─── TEMP / GENERATED FILES ───
*.tmp
*.log
*.bak
*~
.~lock.*#